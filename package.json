    "fonts:update": "node scripts/setup-fonts.mjs",
    "test:filters": "node --experimental-strip-types scripts/test-filters.mjs",
    "typecheck": "nuxt prepare && nuxt typecheck && nuxt typecheck fixtures"
  },
  "dependencies": {
