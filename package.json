    "nuxt": "^4.4.8",
    "puppeteer-core": "^25.3.0",
    "typescript": "^5.6.3",
    "vue-tsc": "^2.2.0"
  },
  "peerDependencies": {
    "nuxt": "^4.0.0"
  }
