{
  // Solution-style root: extends the canonical baseline, delegates real
  // typechecking to the Nuxt-4 project-references contexts generated by
  // `nuxt prepare` at the engine root. `npm run typecheck` (nuxt typecheck →
  // vue-tsc -b) builds all references, for this root AND the fixtures root.
  "extends": "./tsconfig.base.json",
  "files": [],
  "references": [
    { "path": "./.nuxt/tsconfig.app.json" },
    { "path": "./.nuxt/tsconfig.node.json" },
    { "path": "./.nuxt/tsconfig.shared.json" }
  ]
}
